{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/navigation/**",
              "coopervision/**",
              "coopervision/components/**",
              "coopervision/views/**",
              "ui_kits/dashboard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono|Outfit|Inter))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono, Outfit, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|dot|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:accent|pos|neg|paused|test|neutral|dark)$/]",
        "message": "<Badge> variant must be one of 'accent' | 'pos' | 'neg' | 'paused' | 'test' | 'neutral' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|disabled|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, disabled, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|accent|dark)$/]",
        "message": "<Card> variant must be one of 'default' | 'accent' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:default|compact)$/]",
        "message": "<Card> padding must be one of 'default' | 'compact'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Delta'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|invert|key|ref|className|style|children)$/]",
        "message": "<Delta> doesn't accept that prop. Declared props: value, invert."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|type|label|disabled|error|icon|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, type, label, disabled, error, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email|password|number|search)$/]",
        "message": "<Input> type must be one of 'text' | 'email' | 'password' | 'number' | 'search'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|delta|data|accent|invert|prefix|suffix|compact|key|ref|className|style|children)$/]",
        "message": "<KPICard> doesn't accept that prop. Declared props: label, value, delta, data, accent, invert, prefix, suffix, compact."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|active|onClick|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: icon, label, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|color|width|height|fill|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: data, color, width, height, fill, strokeWidth."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
