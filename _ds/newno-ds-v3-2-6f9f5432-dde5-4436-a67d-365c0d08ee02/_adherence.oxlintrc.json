{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/atoms/Avatar/**",
              "components/atoms/Button/**",
              "components/atoms/ChannelChip/**",
              "components/atoms/Delta/**",
              "components/atoms/FilterChips/**",
              "components/atoms/Pill/**",
              "components/atoms/SearchInput/**",
              "components/atoms/Segmented/**",
              "components/atoms/Toggle/**",
              "components/data/AIInsight/**",
              "components/data/AreaChart/**",
              "components/data/ChannelDonut/**",
              "components/data/DataTable/**",
              "components/data/KPICard/**",
              "components/data/ProgressBar/**",
              "components/data/Sparkline/**",
              "components/icons/Icon/**",
              "components/shell/AppShell/**",
              "components/shell/PageHeader/**",
              "components/shell/Sidebar/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono|Outfit|Inter))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono, Outfit, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIInsight'] > JSXAttribute > JSXIdentifier[name!=/^(?:severity|title|body|meta|onApply|applyLabel|secondaryLabel|onSecondary|style|key|ref|className|style|children)$/]",
        "message": "<AIInsight> doesn't accept that prop. Declared props: severity, title, body, meta, onApply, applyLabel, secondaryLabel, onSecondary, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIInsight'] > JSXAttribute[name.name='severity'] > Literal[value!=/^(?:opportunity|critical)$/]",
        "message": "<AIInsight> severity must be one of 'opportunity' | 'critical'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppShell'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onNav|items|brand|monogram|account|accountMeta|footerAction|children|defaultOpen|persistKey|width|height|compact|style|key|ref|className|style|children)$/]",
        "message": "<AppShell> doesn't accept that prop. Declared props: active, onNav, items, brand, monogram, account, accountMeta, footerAction, children, defaultOpen, persistKey, width, height, compact, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AreaChart'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|compare|title|height|formatY|legend|xLabels|style|key|ref|className|style|children)$/]",
        "message": "<AreaChart> doesn't accept that prop. Declared props: data, compare, title, height, formatY, legend, xLabels, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|color|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, color, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|onClick|disabled|type|title|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, children, onClick, disabled, type, title, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChannelChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|label|size|style|key|ref|className|style|children)$/]",
        "message": "<ChannelChip> doesn't accept that prop. Declared props: name, label, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChannelDonut'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|title|centerValue|centerLabel|style|key|ref|className|style|children)$/]",
        "message": "<ChannelDonut> doesn't accept that prop. Declared props: data, title, centerValue, centerLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTable'] > JSXAttribute > JSXIdentifier[name!=/^(?:columns|rows|title|action|rowKey|dense|style|key|ref|className|style|children)$/]",
        "message": "<DataTable> doesn't accept that prop. Declared props: columns, rows, title, action, rowKey, dense, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Delta'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|invert|size|decimals|suffix|style|key|ref|className|style|children)$/]",
        "message": "<Delta> doesn't accept that prop. Declared props: value, invert, size, decimals, suffix, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterChips'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<FilterChips> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|stroke|color|style|title|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, stroke, color, style, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|delta|data|accent|invert|prefix|suffix|compact|style|key|ref|className|style|children)$/]",
        "message": "<KPICard> doesn't accept that prop. Declared props: label, value, delta, data, accent, invert, prefix, suffix, compact, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:workspace|title|subtitle|range|onRangeChange|onExport|onNew|showRange|showExport|showPrimary|primaryLabel|actions|style|key|ref|className|style|children)$/]",
        "message": "<PageHeader> doesn't accept that prop. Declared props: workspace, title, subtitle, range, onRangeChange, onExport, onNew, showRange, showExport, showPrimary, primaryLabel, actions, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|style|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|pos|neg|paused|test|neutral|dark)$/]",
        "message": "<Pill> tone must be one of 'accent' | 'pos' | 'neg' | 'paused' | 'test' | 'neutral' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|max|suffix|color|sub|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: label, value, max, suffix, color, sub, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|width|style|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: value, onChange, placeholder, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Segmented'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Segmented> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onNav|items|brand|monogram|account|accountMeta|footerAction|railOpen|onToggle|defaultOpen|style|key|ref|className|style|children)$/]",
        "message": "<Sidebar> doesn't accept that prop. Declared props: active, onNav, items, brand, monogram, account, accountMeta, footerAction, railOpen, onToggle, defaultOpen, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|color|width|height|fill|strokeW|style|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: data, color, width, height, fill, strokeW, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:on|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: on, onClick, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
